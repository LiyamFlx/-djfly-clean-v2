# ==============================================
# 🎵 DJfly Clean - Environment Variables
# ==============================================
# Copy this file to .env.local and fill in your API keys
# Never commit actual API keys to version control!

# ==============================================
# 🤖 AI & MACHINE LEARNING SERVICES
# ==============================================

# OpenAI API (for AI-powered music generation and analysis)
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here
VITE_OPENAI_ORG_ID=org-your-organization-id-here

# Anthropic Claude API (alternative AI service)
VITE_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Replicate API (for AI music generation models)
VITE_REPLICATE_API_TOKEN=r8_your-replicate-token-here

# Hugging Face API (for open-source AI models)
VITE_HUGGINGFACE_API_KEY=hf_your-huggingface-token-here

# ==============================================
# 🎵 MUSIC STREAMING SERVICES
# ==============================================

# Spotify Web API (for music data and streaming)
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id-here
VITE_SPOTIFY_CLIENT_SECRET=your-spotify-client-secret-here
VITE_SPOTIFY_REDIRECT_URI=https://your-domain.vercel.app/auth/spotify/callback

# YouTube Data API (for YouTube music integration)
VITE_YOUTUBE_API_KEY=your-youtube-api-key-here

# SoundCloud API (for SoundCloud integration)
VITE_SOUNDCLOUD_CLIENT_ID=your-soundcloud-client-id-here
VITE_SOUNDCLOUD_CLIENT_SECRET=your-soundcloud-client-secret-here

# Apple Music API (for Apple Music integration)
VITE_APPLE_MUSIC_TEAM_ID=your-apple-team-id-here
VITE_APPLE_MUSIC_KEY_ID=your-apple-key-id-here
VITE_APPLE_MUSIC_PRIVATE_KEY=your-apple-private-key-here

# ==============================================
# 🎤 AUDIO PROCESSING & ANALYSIS
# ==============================================

# Web Audio API Configuration
VITE_AUDIO_SAMPLE_RATE=44100
VITE_AUDIO_BUFFER_SIZE=2048
VITE_AUDIO_ANALYSIS_INTERVAL=100

# AssemblyAI (for advanced audio analysis)
VITE_ASSEMBLYAI_API_KEY=your-assemblyai-key-here

# Deepgram API (for real-time audio processing)
VITE_DEEPGRAM_API_KEY=your-deepgram-key-here

# ==============================================
# 🌐 BACKEND & DATABASE SERVICES
# ==============================================

# Supabase (Database and Authentication)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
VITE_SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Firebase (Alternative database option)
VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id-here
VITE_FIREBASE_APP_ID=your-firebase-app-id-here

# ==============================================
# 🔐 AUTHENTICATION SERVICES
# ==============================================

# Auth0 (User authentication)
VITE_AUTH0_DOMAIN=your-domain.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id-here
VITE_AUTH0_CLIENT_SECRET=your-auth0-client-secret-here

# NextAuth.js Secret (if using NextAuth)
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=https://your-domain.vercel.app

# ==============================================
# 📊 ANALYTICS & MONITORING
# ==============================================

# Google Analytics
VITE_GA_MEASUREMENT_ID=G-your-measurement-id-here

# Mixpanel (Advanced analytics)
VITE_MIXPANEL_TOKEN=your-mixpanel-token-here

# Sentry (Error monitoring)
VITE_SENTRY_DSN=https://your-sentry-dsn-here
VITE_SENTRY_ORG=your-sentry-org
VITE_SENTRY_PROJECT=your-sentry-project

# PostHog (Product analytics)
VITE_POSTHOG_KEY=phc_your-posthog-key-here
VITE_POSTHOG_HOST=https://app.posthog.com

# ==============================================
# 💳 PAYMENT & SUBSCRIPTION
# ==============================================

# Stripe (Payment processing)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ==============================================
# 🚀 DEPLOYMENT & CDN
# ==============================================

# Vercel Configuration
VERCEL_URL=https://your-app.vercel.app
VERCEL_ENV=production

# Cloudinary (Media storage and processing)
VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
VITE_CLOUDINARY_API_KEY=your-cloudinary-api-key-here
CLOUDINARY_API_SECRET=your-cloudinary-api-secret-here

# AWS S3 (File storage)
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# ==============================================
# 🎛️ DJFLY SPECIFIC CONFIGURATION
# ==============================================

# DJfly App Configuration
VITE_APP_NAME=DJfly Clean
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=production

# Magic Match Settings (AI Crowd Analysis)
VITE_MAGIC_MATCH_ENABLED=true
VITE_MAGIC_MATCH_SAMPLE_DURATION=10000
VITE_MAGIC_MATCH_CONFIDENCE_THRESHOLD=0.7

# Magic Set Settings (AI Playlist Generation)
VITE_MAGIC_SET_ENABLED=true
VITE_MAGIC_SET_MAX_TRACKS=50
VITE_MAGIC_SET_GENERATION_TIMEOUT=30000

# Player Settings
VITE_PLAYER_CROSSFADE_DURATION=3000
VITE_PLAYER_MAX_VOLUME=0.9
VITE_PLAYER_BUFFER_SIZE=5

# Producer Analytics Settings
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_BATCH_SIZE=100
VITE_ANALYTICS_FLUSH_INTERVAL=30000

# ==============================================
# 🔧 DEVELOPMENT SETTINGS
# ==============================================

# Development flags (only for local development)
VITE_DEV_MODE=false
VITE_DEBUG_AUDIO=false
VITE_MOCK_AI_RESPONSES=false
VITE_DISABLE_ANALYTICS=false