# DJfly Production Demo Environment
# This file contains demo/mock configurations for live testing

# App Configuration
VITE_APP_NAME="DJfly Demo"
VITE_APP_VERSION="1.2.0"
VITE_APP_ENVIRONMENT="production"

# Demo Mode Settings
VITE_DEV_MODE="false"
VITE_MOCK_AI_RESPONSES="true"
VITE_DISABLE_ANALYTICS="false"

# Feature Flags for Demo
VITE_MAGIC_MATCH_ENABLED="true"
VITE_MAGIC_SET_ENABLED="true"
VITE_ANALYTICS_ENABLED="true"

# Audio Configuration
VITE_AUDIO_SAMPLE_RATE="44100"
VITE_AUDIO_BUFFER_SIZE="2048"
VITE_PLAYER_CROSSFADE_DURATION="3000"
VITE_PLAYER_MAX_VOLUME="90"

# Demo API Configuration (using placeholder values for now)
VITE_OPENAI_API_KEY=""
VITE_SPOTIFY_CLIENT_ID=""
VITE_SPOTIFY_CLIENT_SECRET=""

# Demo Supabase (will need real values for full functionality)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Analytics (optional for demo)
VITE_GA_MEASUREMENT_ID=""
VITE_SENTRY_DSN=""

# Demo Message
VITE_DEMO_MESSAGE="This is a live demo of DJfly v1.2.0. Some features require API keys for full functionality."